<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Background location — required for geofencing while app is not in foreground.
         Must be requested separately with rationale dialog per Android policy. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Activity recognition — detect driving state transitions -->
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Microphone — only used after explicit in-app user tap, never from background -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service — for active monitoring session during driving -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires explicit foreground service types -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Prevent CPU sleep for geofence processing -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Vibrate for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".GasPriceApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GasPriceTracker"
        tools:targetApi="35">

        <!-- Google Maps/Places API key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${GOOGLE_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Geofence broadcast receiver -->
        <receiver
            android:name=".service.GeofenceBroadcastReceiver"
            android:exported="false"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED" />

        <!-- Activity recognition transition receiver -->
        <receiver
            android:name=".service.ActivityTransitionReceiver"
            android:exported="false" />

        <!-- Active monitoring foreground service (location type for Android 14+) -->
        <service
            android:name=".service.MonitoringForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

</manifest>
